# Copy to .env.deploy and fill in. Used by scripts/deploy.sh and provision.sh.
# .env.deploy is gitignored — never commit real host details.

# Required: VPS hostname or IP.
VPS_HOST=terminal.chakri.me

# User that can sudo on the VPS (use root if that's how you log in).
VPS_USER=root

# ADMIN sshd port (NOT the app's port). After moving admin sshd off 22
# this is typically 2222. For the very first provision on a fresh box it's 22.
VPS_SSH_PORT=2222

# Optional overrides (defaults shown):
# BIN_PATH=/usr/local/bin/terminal-app
# SERVICE=terminal-app
